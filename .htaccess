DirectoryIndex index.php
ErrorDocument 404 /404.html

<IfModule mod_mime.c>
  AddType text/markdown md
  AddType text/plain txt
  AddType application/json json
</IfModule>

<IfModule mod_headers.c>
  SetEnvIf Request_URI "^/(index\.html)?$" IS_HOME
  SetEnvIf Request_URI "^/index\.php$" IS_HOME
  Header always set Link "</.well-known/api-catalog>; rel=\"api-catalog\", </llms.txt>; rel=\"describedby\", </sitemap.xml>; rel=\"describedby\", </auth.md>; rel=\"alternate\"; type=\"text/markdown\", </index.md>; rel=\"alternate\"; type=\"text/markdown\"" env=IS_HOME

  <Files "robots.txt">
    Header set Cache-Control "no-store, max-age=0"
  </Files>
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Keep one indexable origin: HTTPS without www.
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} ^www\.soglasovano\.online$ [NC]
  RewriteRule ^ https://soglasovano.online%{REQUEST_URI} [R=301,L]

  # Prefer dynamic robots to bust CDN/edge caches.
  RewriteRule ^robots\.txt$ robots.php [L]

  RewriteRule ^\.well-known/api-catalog$ .well-known/api-catalog.php [L]
  RewriteRule ^\.well-known/oauth-protected-resource$ .well-known/oauth-protected-resource.php [L]

  RewriteRule ^privacy\.html$ privacy.php [L]
  RewriteRule ^terms\.html$ terms.php [L]
  RewriteRule ^case\.html$ case.php [L]

  RewriteRule ^\.well-known/ - [L]
  RewriteRule ^.*\.(json|md|txt|xml)$ - [L]
  RewriteRule ^api/ - [L]
  RewriteRule ^docs/ - [L]

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ - [R=404,L]
</IfModule>
